# GEMINI_API_KEY: Required for Gemini AI API calls if fallback check is needed.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Required for OpenRouter API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL_ID: The specific model ID to use on OpenRouter.
# Defaults to google/gemini-2.5-flash if left blank.
OPENROUTER_MODEL_ID="google/gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
